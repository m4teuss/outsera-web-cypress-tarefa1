{
    "name": "web.tests",
    "version": "2.0.0",
    "private": true,
    "description": "Testes web",
    "scripts": {
        "cy:chrome": "cypress run -b chrome",
        "cy:report": "node ./cypress/report.js",
        "cy:open:dev": "cypress open"
    },
    "cypress-cucumber-preprocessor": {
        "step_definitions": "cypress/support/step_definitions",
        "json": {
            "enabled": true,
            "output": "cypress/reports/cucumber-report.json"
        }
    },
    "devDependencies": {
        "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
        "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
        "cypress": "^14.0.2",
        "cypress-xpath": "^1.6.2",
        "esbuild": "^0.27.4"
    }
}